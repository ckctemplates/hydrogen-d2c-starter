# Hydrogen D2C Starter — environment variables
#
# Local dev: copy this file to .env and fill in your values, OR
#   pnpm shopify hydrogen link
#   pnpm shopify hydrogen env pull
#
# .env is gitignored — never commit it.

# Any random string used to sign HMR / session cookies.
SESSION_SECRET=replace-me-with-a-random-string

# Your Shopify storefront — pull from Settings → Apps and sales channels → Hydrogen
PUBLIC_STORE_DOMAIN=your-store.myshopify.com
PUBLIC_STOREFRONT_API_TOKEN=
PUBLIC_STOREFRONT_API_VERSION=
PUBLIC_CHECKOUT_DOMAIN=your-store.myshopify.com

# Required for the customer-accounts routes (login / orders / addresses)
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
PUBLIC_CUSTOMER_ACCOUNT_API_URL=

# Optional — image search for the design lab.
# Server-side / build-time only — never expose this in the client bundle.
UNSPLASH_ACCESS_KEY=
